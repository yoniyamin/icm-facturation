# NextAuth (generate secret with: openssl rand -base64 32)
NEXTAUTH_SECRET=your-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# Google OAuth credentials (APIs & Services > Credentials > OAuth 2.0 Client ID)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Comma-separated list of seed admins. These emails are always allowed in
# AND can manage the dynamic user list from the in-app modal. They cannot
# be removed via the UI (they're your safety net against lockout).
# Falls back to ALLOWED_EMAILS if ADMIN_EMAILS is not set.
ADMIN_EMAILS=alice@gmail.com,bob@gmail.com

# Legacy: kept for back-compat. If ADMIN_EMAILS is unset, this list is
# treated as seed admins. Leave both empty to allow all.
# ALLOWED_EMAILS=

# Vercel Edge Config — stores the dynamic allowed-users list (admin-managed
# via the in-app modal). Create one at vercel.com/dashboard/stores then
# link it to the project; Vercel will inject EDGE_CONFIG automatically on
# deploy. For local dev, copy the connection string from the dashboard.
EDGE_CONFIG=https://edge-config.vercel.com/ecfg_xxx?token=xxx

# Vercel API token with write access to Edge Config (required to update
# the user list from the modal). Create at vercel.com/account/tokens.
VERCEL_API_TOKEN=your-vercel-api-token

# Optional: only needed if the Edge Config lives under a Vercel team.
# VERCEL_TEAM_ID=team_xxx

# Storage mode: "local" for disk storage testing, "cloud" for Cloudinary + Google Sheets
NEXT_PUBLIC_STORAGE_MODE=local

# Local storage path (only used when STORAGE_MODE=local)
# Defaults to ./receipts in the project root if not set
# LOCAL_STORAGE_PATH=C:\path\to\receipts

# Cloudinary credentials (for receipt image storage)
# Sign up free at https://cloudinary.com and copy from the dashboard
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Google Service Account credentials (for Google Sheets summary)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Google Sheet ID (from the spreadsheet URL: https://docs.google.com/spreadsheets/d/SHEET_ID/edit)
GOOGLE_SHEET_ID=your-sheet-id-here
